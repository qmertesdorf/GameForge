# Godot 4 editor cache / generated
.godot/

# Build outputs
/builds/
*.apk
*.aab
*.ipa

# Secrets — never commit
*.keystore
*.p12
*.mobileprovision

# Per-game Android build outputs (APK/AAB already ignored by extension; this
# also keeps the build dir itself out of git status)
games/*/build/

# Local-only Android signing config (paths + passwords for the release keystore).
# The release keystore is referenced by buildArtifact() via env vars sourced from
# this file; it MUST NOT be committed.
tools/android-signing.local.json
*-signing.local.json

# OS cruft
.DS_Store
Thumbs.db

# Node
node_modules/
.gstack/

# Claude Code runtime artifacts
.claude/scheduled_tasks.lock

# Throwaway calibration/probe artifacts (skill A/B rounds). Convention: a leading
# underscore = scratch, never committed. Locked winners live in the SKILL.md /
# probe-results docs, so these are reproducible — keep them out of `git status`.
tools/_*.mjs
**/_probe_*
**/_aud_*
